programa {
	funcao inicio() {
		// Estrutura inicial
		inteiro numero1, numero2, soma
		// Estrutura da soma
		escreva("Digite o primeiro número: ")
		leia(numero1)
		
		escreva("Digite o segundo número: ")
		leia(numero2)
		
		soma = numero1 + numero2
		
		escreva("O resultado da soma é: ", soma)
	}
}
